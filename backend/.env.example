# ----------------------------------------------------------------------------------
# SECURITY VARIABLES (STRICTLY REQUIRED FOR PRODUCTION)
# ----------------------------------------------------------------------------------
# Used to verify JWTs; generate using `openssl rand -hex 32` or python `secrets.token_urlsafe(32)`
SECRET_KEY=your_super_secret_jwt_key_here

# Used to encrypt database credentials in the DB; generate using `cryptography.fernet.Fernet.generate_key().decode()`
FERNET_KEY=your_generated_fernet_key_here_must_be_32_url_safe_base64

# ----------------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# ----------------------------------------------------------------------------------
# The database where users and session history will be stored
DATABASE_URL=postgresql://user:password@host:port/dbname

# External API used for Natural Language to SQL features
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key

# URL of the frontend (used for CORS mapping)
FRONTEND_URL=http://localhost:5173

# Allows users to connect to local databases (localhost, 127.0.0.1, internal networks)
# Set to 'false' in production to prevent Server-Side Request Forgery!
ALLOW_LOCAL_DB=true
